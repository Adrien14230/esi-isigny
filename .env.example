# ============================================================
# ESI Isigny — Environment variables
# Copy to .env.local for local dev. Add to Vercel dashboard for prod.
# ============================================================

# Anthropic Claude API (agents 04, 06, 07)
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (DB + auth + storage)
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci.xxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_ANON_KEY=eyJhbGci.xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend (transactional emails — agent 05 reminders)
# https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Meta Graph API (agent 06 — Instagram + Facebook auto-posting)
# https://developers.facebook.com/apps/
META_PAGE_ID=000000000000000
META_PAGE_ACCESS_TOKEN=EAABxxxxxxxxxxxxxxxxxxxxxxxxxxx
IG_BUSINESS_ACCOUNT_ID=000000000000000

# Validator email — only this address can validate new licenciés
VALIDATOR_EMAIL=adrien.goubert1@icloud.com

# Cron secret (Vercel auto-injects but we double-check)
CRON_SECRET=generate-a-random-string-here-32-chars-min

# Public site URL
NEXT_PUBLIC_SITE_URL=https://esi-isigny.fr
